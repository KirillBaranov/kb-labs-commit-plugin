{
  "name": "@kb-labs/commit-cli",
  "version": "0.6.0",
  "type": "module",
  "description": "CLI commands and manifest for KB Labs Commit plugin - AI-powered commit generation.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin-manifest": {
      "import": "./dist/manifest.js",
      "types": "./dist/manifest.d.ts"
    },
    "./cli": "./dist/cli/index.js",
    "./lifecycle": "./dist/lifecycle/index.js",
    "./dist/*": "./dist/*"
  },
  "kb": {
    "manifest": "./dist/manifest.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "pretype-check": "pnpm --filter @kb-labs/commit-cli build",
    "clean": "rimraf dist",
    "build": "tsup --config tsup.config.ts && pnpm run build:studio",
    "build:cli": "tsup --config tsup.config.ts",
    "build:studio": "rspack build --config rspack.studio.config.mjs",
    "dev": "tsup --config tsup.config.ts --watch",
    "dev:studio": "rspack serve --config rspack.studio.config.mjs",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kb-labs/commit-contracts": "workspace:*",
    "@kb-labs/commit-core": "workspace:*",
    "@kb-labs/sdk": "link:../../../../platform/kb-labs-sdk/packages/sdk",
    "glob": "^11.0.0"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "antd": "^5.21.0",
    "@ant-design/icons": "^5.4.0",
    "@tanstack/react-query": "^5.0.0",
    "react-router-dom": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "antd": {
      "optional": true
    },
    "@ant-design/icons": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "react-router-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kb-labs/devkit": "link:../../../../infra/kb-labs-devkit",
    "@kb-labs/studio-plugin-tools": "link:../../../../platform/kb-labs-studio/packages/studio-plugin-tools",
    "@types/node": "^24.3.3",
    "@rspack/cli": "^1.7.0",
    "@rspack/core": "^1.7.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
